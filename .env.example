# ── REQUERIDAS (pipeline completo operativo) ───────────────────────────────────
VITE_COMFYDEPLOY_API_KEY=your_comfydeploy_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Railway / preview web server ──────────────────────────────────────────────
# Railway define PORT automaticamente. Localmente el default sigue siendo 3333.
PORT=3333
# Local: 127.0.0.1. Railway usa 0.0.0.0 automaticamente si RAILWAY_ENVIRONMENT existe.
HOST=127.0.0.1
# Persistencia temporal para Railway Volume. Ejemplo recomendado en Railway: /data
# Si queda vacio, localmente se usa ./data
PERSISTENCE_DIR=

# ── ComfyCloud — REQUERIDA para botón "✦ Más Sexy" (Fase 4C) ──────────────────
# Genera tu API key en: https://platform.comfy.org/profile/api-keys
COMFYCLOUD_API_KEY=your_comfycloud_api_key

# ── Deployment IDs ComfyDeploy ─────────────────────────────────────────────────
VITE_COMFYDEPLOY_AION_DEPLOYMENT_ID=e833a575-893b-49f2-8687-4aa5291d31cc
# Fase 4 UGC — 14 slots GeminiImage2Node, genera 8 imágenes de contenido
VITE_COMFYDEPLOY_CONTENT_DEPLOYMENT_ID=f9822b81-9ebc-48e2-b39c-0e8034e90554
# Legacy (no usados en flujo principal):
VITE_COMFYDEPLOY_BODY_DEPLOYMENT_ID=cabf22a3-a697-485c-a6df-b6c09ee4f2f1

# ── Supabase Storage (upload de imágenes de referencia AION) ───────────────────
VITE_SUPABASE_URL=https://vtyuylgfjvleywupbdzl.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_BUCKET=zami-images

# ── Pendientes (fases futuras) ─────────────────────────────────────────────────
VITE_COMFYDEPLOY_NSFW_DEPLOYMENT_ID=
VITE_FAL_API_KEY=
